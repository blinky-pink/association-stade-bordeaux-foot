{% extends 'base.html.twig' %}

{% block title %}Événement {{ event.title }}{% endblock %}

{% block body %}
<h1>{{ event.title }}</h1>

<p>Type : {{ event.type }}</p>
<p>Date : {{ event.eventDate|date('d/m/Y') }}</p>
<p>Coach : {{ event.coach.name }}</p>

{% if event.description %}
    <p>Description : {{ event.description }}</p>
{% endif %}

<h2>Présences</h2>
<ul>
    {% for presence in event.getPresences() %}
        <li>
            {{ presence.getPlayer().getFirstName() }} {{ presence.getPlayer().getLastName() }}
            — {{ presence.status }}
        </li>
    {% else %}
        <li>Aucune présence enregistrée.</li>
    {% endfor %}
</ul>

<a href="{{ path('event_list') }}">Retour à la liste</a>
{% endblock %}