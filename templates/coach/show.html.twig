{% extends 'base.html.twig' %}

{% block title %}Coach {{ coach.name }}{% endblock %}

{% block body %}
<h1>Coach : {{ coach.name }}</h1>

<div class="show-info">
    {% if coach.licence %}
    <p><strong>Licence :</strong> {{ coach.licence }}</p>
    {% endif %}
</div>

<h2>Ses équipes</h2>
<table>
    <thead>
        <tr>
            <th>Équipe</th>
        </tr>
    </thead>
    <tbody>
        {% for team in coach.getTeams() %}
        <tr>
            <td><a href="{{ path('team_show', {id: team.id}) }}">{{ team.name }}</a></td>
        </tr>
        {% else %}
        <tr><td class="td-empty">Aucune équipe.</td></tr>
        {% endfor %}
    </tbody>
</table>

<h2>Ses événements</h2>
<table>
    <thead>
        <tr>
            <th>Titre</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        {% for event in coach.getEvents() %}
        <tr>
            <td>{{ event.title }}</td>
            <td>{{ event.eventDate|date('d/m/Y') }}</td>
        </tr>
        {% else %}
        <tr><td colspan="2" class="td-empty">Aucun événement.</td></tr>
        {% endfor %}
    </tbody>
</table>

<div class="show-actions">
    <a href="{{ path('coach_list') }}" class="btn btn-secondary">Retour à la liste</a>
</div>
{% endblock %}
