{% extends 'base.html.twig' %}

{% block title %}Équipe {{ team.name }}{% endblock %}

{% block body %}
<h1>Équipe : {{ team.name }}</h1>

{% if team.coach %}
<div class="show-info">
    <p><strong>Coach :</strong> {{ team.coach.name }}</p>
</div>
{% endif %}

<h2>Joueurs</h2>
<table>
    <thead>
        <tr>
            <th>Prénom</th>
            <th>Nom</th>
        </tr>
    </thead>
    <tbody>
        {% for player in team.getPlayers() %}
        <tr>
            <td>{{ player.firstName }}</td>
            <td>{{ player.lastName }}</td>
        </tr>
        {% else %}
        <tr><td colspan="2" class="td-empty">Aucun joueur dans cette équipe.</td></tr>
        {% endfor %}
    </tbody>
</table>

<div class="show-actions">
    <a href="{{ path('team_attendance', {id: team.id, eventId: 1}) }}" class="btn btn-primary">Gérer les présences</a>
    <a href="{{ path('team_list') }}" class="btn btn-secondary">Retour à la liste</a>
</div>
{% endblock %}
