{% extends 'base.html.twig' %}

{% block title %}Liste des équipes{% endblock %}

{% block body %}
<h1>Les équipes</h1>

<a href="{{ path('team_create') }}">+ Ajouter une équipe</a>

<ul>
    {% for team in teams %}
        <li>
            <a href="{{ path('team_show', {id: team.id}) }}">
                {{ team.name }}
            </a>
            {% if team.coach %}
                - Coach : {{ team.coach.name }}
            {% endif %}
            | <a href="{{ path('team_edit', {id: team.id}) }}">Modifier</a>
            | <a href="{{ path('team_delete', {id: team.id}) }}"
                onclick="return confirm('Supprimer cette équipe ?')">Supprimer</a>
        </li>
    {% else %}
        <li>Aucune équipe trouvée.</li>
    {% endfor %}
</ul>
{% endblock %}