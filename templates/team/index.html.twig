{% extends 'base.html.twig' %}

{% block title %}Liste des équipes{% endblock %}

{% block body %}
<h1>Les équipes</h1>

<div class="actions-bar">
    <a href="{{ path('team_create') }}" class="btn btn-primary">+ Ajouter une équipe</a>
</div>

<table>
    <thead>
        <tr>
            <th>Équipe</th>
            <th>Coach</th>
            <th class="text-right">Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for team in teams %}
        <tr>
            <td><a href="{{ path('team_show', {id: team.id}) }}"><strong>{{ team.name }}</strong></a></td>
            <td>{% if team.coach %}{{ team.coach.name }}{% else %}<span class="muted">—</span>{% endif %}</td>
            <td class="td-actions">
                <a href="{{ path('team_show', {id: team.id}) }}" class="btn btn-gold">Voir</a>
                <a href="{{ path('team_edit', {id: team.id}) }}" class="btn btn-secondary">Modifier</a>
                <a href="{{ path('team_delete', {id: team.id}) }}" class="btn btn-delete" onclick="return confirm('Supprimer cette équipe ?')">Supprimer</a>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="3" class="td-empty">Aucune équipe trouvée.</td></tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}