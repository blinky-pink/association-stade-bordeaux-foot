{% extends 'base.html.twig' %}

{% block title %}Liste des joueurs{% endblock %}

{% block body %}
<h1>Les joueurs</h1>

{# Lien pour ajouter un joueur #}
<a href="{{ path('player_create') }}">+ Ajouter un joueur</a>

<ul>
    {% for player in players %}
        <li>
            <a href="{{ path('player_show', {id: player.id}) }}">
                {{ player.firstName }} {{ player.lastName }}
            </a>
            — Équipe : {{ player.team.name }}
            — Né le : {{ player.birthDate|date('d/m/Y') }}
            | <a href="{{ path('player_edit', {id: player.id}) }}">Modifier</a>
            | <a href="{{ path('player_delete', {id: player.id}) }}"
                 onclick="return confirm('Supprimer ce joueur ?')">Supprimer</a>
        </li>
    {% else %}
        <li>Aucun joueur trouvé.</li>
    {% endfor %}
</ul>
{% endblock %}