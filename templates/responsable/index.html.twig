{% extends 'base.html.twig' %}

{% block title %}Liste des responsables{% endblock %}

{% block body %}
<h1>Les responsables</h1>

<div class="actions-bar">
    <a href="{{ path('responsable_create') }}" class="btn btn-primary">+ Ajouter un responsable</a>
</div>

<table>
    <thead>
        <tr>
            <th>Nom</th>
            <th>Joueur associé</th>
            <th>Téléphone</th>
            <th class="text-right">Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for responsable in responsables %}
        <tr>
            <td><a href="{{ path('responsable_show', {id: responsable.id}) }}"><strong>{{ responsable.name }}</strong></a></td>
            <td>{{ responsable.player.firstName }} {{ responsable.player.lastName }}</td>
            <td>{{ responsable.phone }}</td>
            <td class="td-actions">
                <a href="{{ path('responsable_edit', {id: responsable.id}) }}" class="btn btn-secondary">Modifier</a>
                <a href="{{ path('responsable_delete', {id: responsable.id}) }}" class="btn btn-delete" onclick="return confirm('Supprimer ce responsable ?')">Supprimer</a>
            </td>
        </tr>
        {% else %}
        <tr><td colspan="4" class="td-empty">Aucun responsable trouvé.</td></tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
