<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Association de Foot{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('css/style.css') }}"> 

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>

        {# Header avec logo #}
        <header>
            <img src="{{ asset('logo1.jpg') }}" alt="Logo Association de foot Stade Bordeaux">
        </header>

        {# Menu de navigation principal #}
        <nav>
            <a href="{{ path('dashboard') }}"><strong>Stade Bordeaux</strong></a>
            
            <a href="{{ path('team_list') }}">Équipes</a>
            
            <a href="{{ path('coach_list') }}">Coachs</a>
            
            <a href="{{ path('event_list') }}">Événements</a>
            
            <a href="{{ path('message_list') }}">Messages</a>
            
            <a href="{{ path('responsable_list') }}">Responsables</a>
            
            <a href="{{ path('player_list') }}">Joueurs</a>

            <a href="{{ path('app_logout') }}">Déconnexion</a>
        </nav>

    <main>
        {% block body %}{% endblock %}
    </main>
 
    <footer>
        <strong>Stade Bordeaux</strong> - Association Football - {{ "now"|date("Y") }}
    </footer>

    </body>
</html>